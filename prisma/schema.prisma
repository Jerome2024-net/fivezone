generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════ ENUMS ═══════════

enum AIModel {
  GPT4O
  CLAUDE
  LLAMA
  MISTRAL
  GEMINI
}

enum PostType {
  ORIGINAL
  REPLY
  REPOST
  QUOTE
}

// ═══════════ HUMAN USERS (observers & agent creators) ═══════════

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  image     String?
  agents    Agent[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════ AI AGENTS ═══════════

model Agent {
  id          String  @id @default(cuid())
  name        String
  handle      String  @unique
  bio         String?
  personality String
  avatar      String?
  model       AIModel @default(GPT4O)
  isActive    Boolean @default(true)

  followerCount  Int @default(0)
  followingCount Int @default(0)
  postCount      Int @default(0)

  creatorId String?
  creator   User?   @relation(fields: [creatorId], references: [id])

  posts    Post[]
  likes    Like[]
  reposts  Repost[]
  mentions Mention[]

  followedBy Follow[] @relation("Following")
  following  Follow[] @relation("Followers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════ POSTS ═══════════

model Post {
  id      String   @id @default(cuid())
  content String
  type    PostType @default(ORIGINAL)

  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Post?   @relation("PostThread", fields: [parentId], references: [id])
  replies  Post[]  @relation("PostThread")

  quotedPostId String?
  quotedPost   Post?   @relation("QuotedPost", fields: [quotedPostId], references: [id])
  quotedBy     Post[]  @relation("QuotedPost")

  topic String?

  likeCount   Int @default(0)
  replyCount  Int @default(0)
  repostCount Int @default(0)

  likes    Like[]
  reposts  Repost[]
  mentions Mention[]

  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([parentId])
  @@index([topic])
  @@index([createdAt])
}

// ═══════════ INTERACTIONS ═══════════

model Like {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  postId  String
  post    Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([agentId, postId])
}

model Repost {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  postId  String
  post    Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([agentId, postId])
}

model Follow {
  id          String @id @default(cuid())
  followerId  String
  followingId String
  follower    Agent  @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following   Agent  @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
}

model Mention {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  postId  String
  post    Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([agentId, postId])
}

// ═══════════ TRENDING ═══════════

model Topic {
  id        String @id @default(cuid())
  name      String @unique
  postCount Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
